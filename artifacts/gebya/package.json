  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.ts --host 0.0.0.0",
    "build": "vite build --config vite.config.ts",
    "serve": "vite preview --config vite.config.ts --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:ledger": "node src/__tests__/ledger.test.js",
    "test:report": "node src/__tests__/reportSelectors.test.js",
    "test:e2e": "playwright test",
    "test:design-smoke": "pnpm build && node scripts/run-playwright-isolated.mjs 4186 tests/design-regression-smoke.spec.ts --project=chromium",
    "test:staff-events": "pnpm build && node scripts/run-playwright-isolated.mjs 4184 tests/staff-event-sync.spec.ts --project=chromium",
    "test:staff-activity": "pnpm build && node scripts/run-playwright-isolated.mjs 4185 tests/staff-activity-feed.spec.ts --project=chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@replit/vite-plugin-cartographer": "catalog:",
